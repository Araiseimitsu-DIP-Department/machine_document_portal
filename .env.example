APP_NAME=Machine Document Portal
APP_ENV=development
DEBUG=false
USE_SAMPLE_DATA=true
PERSISTENCE_MODE=memory

# PERSISTENCE_MODE=memory の間は、以下のPostgreSQL設定は使用されません。
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/machine_document_portal
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT=10

GOOGLE_CREDENTIALS_PATH=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SPREADSHEET_SHEET_NAME=
GOOGLE_SPREADSHEET_START_ROW=2
GOOGLE_SPREADSHEET_MACHINE_COLUMN=A
GOOGLE_SPREADSHEET_PART_NUMBER_COLUMN=B
GOOGLE_SPREADSHEET_PRODUCT_NAME_COLUMN=C
GOOGLE_SPREADSHEET_STATUS_COLUMN=D
GOOGLE_SPREADSHEET_UPDATED_AT_COLUMN=E
GOOGLE_SPREADSHEET_ACTIVE_STATUS=生産中
GOOGLE_DRIVE_DRAWING_FOLDER_ID=

SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_FOLDER_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

AUTO_REFRESH_SECONDS=300
MEMORY_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
